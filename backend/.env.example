# Copy this to .env and fill in your values
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mie237_experiment
DB_USER=postgres
DB_PASSWORD=yourpassword

# Session secret (generate a random string)
SESSION_SECRET=change_this_to_a_random_secret_string

# Admin credentials (set these before first run)
ADMIN_USERNAME=supervisor
ADMIN_PASSWORD=changeme123

# Owner password (used to reset admin credentials)
OWNER_PASSWORD=owner_secret_change_me

# Upload directory (relative to backend root)
UPLOAD_DIR=uploads
